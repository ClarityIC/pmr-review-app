# ─── Google OAuth ────────────────────────────────────────────────────────────
# OAuth 2.0 Client ID from GCP Console (Web application type)
# Authorized redirect URI must include: https://pmr.clarityic.com/api/auth/google-redirect
GOOGLE_CLIENT_ID=

# ─── Session ─────────────────────────────────────────────────────────────────
# Random 64+ character string for signing session cookies
SESSION_SECRET=

# ─── GCP Service Account ─────────────────────────────────────────────────────
# Paste the entire service account JSON as a single-line string
# Required roles: Storage Admin, BigQuery Admin, Document AI Editor, Firestore Owner
GCP_SA_KEY=

# ─── GCP Resource Names ──────────────────────────────────────────────────────
GCP_PROJECT_ID=cic-prior-records-review
GCP_LOCATION=us
GCS_AUTHORITATIVE_BUCKET=cic-authoritative-case-files
GCS_STAGING_INPUT_BUCKET=cic-docai-staging-inputs
GCS_STAGING_OUTPUT_BUCKET=cic-docai-staging-outputs
BQ_DATASET=prr_data
BQ_TABLE0=documents

# ─── Document AI Processor IDs ───────────────────────────────────────────────
# Set after running: npm run setup-gcp
DOCAI_OCR_PROCESSOR_ID=
DOCAI_LAYOUT_PROCESSOR_ID=

# ─── Gemini / Vertex AI ──────────────────────────────────────────────────────
GEMINI_MODEL=gemini-3.1-pro-preview
VERTEX_LOCATION=us-central1

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
